    "Flowe doesn't collect session fees — students pay you directly, so they need to know how.": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "لا تحصّل Flowe رسوم الجلسات — يدفع لك الطلاب مباشرةً، لذا يحتاجون إلى معرفة الطريقة."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Flowe no cobra las tarifas de las sesiones: los alumnos te pagan directamente, así que necesitan saber cómo."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Flowe ne perçoit pas les frais de séance : les élèves vous paient directement, ils doivent donc savoir comment."
          }
        }
      }
    },
